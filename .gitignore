# ==============================================================
# Aura AI Assistant — .gitignore
# ==============================================================

# ---- Python bytecode & caches ----
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---- Virtual environments ----
.venv/
venv/
env/
.env/

# ---- IDE / editor configs ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Aura runtime data (user-specific, regenerated at runtime) ----
memory.json
test_memory.json
reminders.json

# ---- Aura binary assets (too large for Git) ----
piper/
vosk-model-*/
*.onnx

# ---- Audio output (generated at runtime by Piper TTS) ----
outputs/
*.wav

# ---- Logs ----
*.log

# ---- OS junk ----
Thumbs.db
Desktop.ini
.DS_Store

# ---- Distribution / packaging ----
dist/
build/
*.egg-info/
*.egg
*.manifest
*.spec

# ---- Testing / Coverage ----
.pytest_cache/
.tox/
.coverage
.cache/
nosetests.xml
coverage.xml
*.cover
htmlcov/

# ---- System and temporary files ----
*.tmp
*.temp
.python-version
pip-log.txt
pip-delete-this-directory.txt

